# Copy this file to ".env" and fill in real values.

# --- Required ---------------------------------------------------------------

# Your OpenAI API key (used for both transcription and fact-checking).
OPENAI_API_KEY=sk-...

# Secret used to sign login tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-string

# --- Database ---------------------------------------------------------------
# Leave unset to use a local SQLite file (./local.db) for development.
# For production, paste your Postgres connection string here. On Railway,
# add a Postgres plugin and it injects DATABASE_URL automatically — but it
# uses the "postgresql://" prefix, which you must change to
# "postgresql+psycopg://" so SQLAlchemy uses the psycopg 3 driver.
#
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# --- CORS -------------------------------------------------------------------
# Comma-separated list of the front-end origin(s) allowed to call this API.
# In production set this to your deployed frontend URL.
FRONTEND_ORIGINS=http://localhost:5173
